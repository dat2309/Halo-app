# =============================================================================
# Halo App — environment variables
# Copy to .env.development / .env.staging / .env.production based on APP_ENV.
# NEVER commit real .env files — they're in .gitignore.
# =============================================================================

# Backend API URL — must include `/api` prefix
# - iOS Simulator: http://localhost:3000/api
# - Android Emulator: http://10.0.2.2:3000/api  (10.0.2.2 = host loopback)
# - Physical device: http://<MAC-LAN-IP>:3000/api (e.g. http://192.168.1.10:3000/api)
API_URL=http://localhost:3000/api

# Build-time secret. For sample project, any non-empty value works.
# In production, move this out of the env file (use EAS Secrets).
SECRET_KEY=change-me

# Example typed env vars (kept from upstream template)
VAR_NUMBER=10
VAR_BOOL=true
