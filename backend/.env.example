# =============================================================================
# Halo Backend — environment variables
# Copy this file to `.env` and fill in real values.
# NEVER commit your real .env — see .gitignore.
# =============================================================================

# ---- MongoDB ---------------------------------------------------------------
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/halo
# Local with auth: mongodb://admin:admin@localhost:27017/halo?authSource=admin
# Local no auth: mongodb://localhost:27017/halo
MONGODB_URI=mongodb://localhost:27017/halo

# ---- Auth ------------------------------------------------------------------
# Generate a strong random secret for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-something-random-and-long
JWT_EXPIRES_IN=1h

# ---- Server ----------------------------------------------------------------
PORT=3000
BASE_URL=http://localhost:3000

# ---- Cloudinary (required for file uploads) --------------------------------
# Sign up free at https://cloudinary.com/console
# Dashboard → "API Environment variable" copy each value
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder to organize uploads
CLOUDINARY_FOLDER=halo

# ---- TURN servers (optional — OpenRelay is used by default) ----------------
# Get free 50GB/month TURN at https://www.metered.ca/
# When both METERED_API_KEY and METERED_SUBDOMAIN are set, backend will use
# Metered managed TURN with short-lived credentials. Otherwise OpenRelay
# (public free) is returned. Set DISABLE_TURN=true to fall back to STUN-only.
# METERED_API_KEY=
# METERED_SUBDOMAIN=halo
# DISABLE_TURN=false

# ---- Build metadata (optional) ---------------------------------------------
CONFIG_BUILD_NUMBER=1.0.0
CONFIG_BUILD_TIME=2024-01-01T00:00:00Z
